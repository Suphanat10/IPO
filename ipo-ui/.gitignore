# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Derived per-slice data artifacts — generated by runBuild from ipo.json.
# Not source: /api/ipo-data/* falls back to deriving slices from the committed
# ipo.json when these are absent (see src/lib/artifact.ts).
/src/app/data/ipo/

# QA report outputs
/outputs/
# Scraper CSV outputs
/scripts/output/
# Local test scripts
/scripts/test-set-api.mjs
