# =====================================================
# IPO Admin Dashboard — environment template
# Copy to .env.local and fill in values
# =====================================================

# PostgreSQL connection
POSTGRES_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres.xxxxxxxxxxxxxxxxxxxx
POSTGRES_PASSWORD=your-database-password-here

# Admin session secret (HS256 JWT signing key)
SESSION_SECRET=your-session-secret-here

# AES-256-GCM key for encrypting API responses (32 bytes hex = 64 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXT_PUBLIC_API_CIPHER_KEY=your-64-char-hex-key-here

# GitHub Actions — for triggering build pipeline (set in /admin server only)
GH_TOKEN=ghp_...
GH_REPO=Suphanat10/IPO
GH_WORKFLOW=build.yml

# Scraper performance
# missing = skip SEC filing pages for existing IPOs that already have SEC-derived fields
# full = always refresh SEC filing pages
SCRAPER_SEC_PAGE_MODE=missing
# missing = deep SEC docs only for new IPOs or IPOs without stored financial docs
# full = always refresh deep SEC docs, skip = SET + SEC filing page only
SCRAPER_SEC_DOC_MODE=missing
SCRAPER_SEC_DOC_CACHE=1
SCRAPER_SEC_DOC_CACHE_TTL_HOURS=168
SCRAPER_SEC_PAGE_CACHE_TTL_MINUTES=30
SCRAPER_SEC_FS_MAX_BYTES=5000000
SCRAPER_SEC_WORKERS=3
SCRAPER_SEC_DOC_WORKERS=3
SCRAPER_RUN_TIMEOUT_MS=1800000
SCRAPER_STALE_RUN_MS=2100000
