# =====================================================
# IPO Performance Analytics — environment template
# Copy to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit real secrets.
# =====================================================

# ----- Database (REQUIRED for /ipo admin dashboard + API routes) -----
# Preferred: single connection string. Use the Supabase *pooler* host
# (port 6543 = transaction mode) — the direct db.<ref>.supabase.co host
# is IPv6-only on most plans and fails on IPv4-only platforms.
# Format: postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:your-password@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# Alternative to DATABASE_URL — discrete params (used only if DATABASE_URL is unset):
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=postgres
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your-database-password

# Optional DB query retry tuning (defaults shown)
# DB_QUERY_RETRIES=2
# DB_RETRY_BASE_DELAY_MS=250

# ----- Auth (REQUIRED for admin login/sessions) -----
# HS256 JWT signing key. Generate: openssl rand -base64 32
SESSION_SECRET=your-session-secret-here

# ----- API response encryption (REQUIRED) -----
# AES-256-GCM key, 32 bytes hex (64 chars). Shared by server + client.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXT_PUBLIC_API_CIPHER_KEY=your-64-char-hex-key-here

# ----- Build pipeline trigger (OPTIONAL — only /ipo "Builds" page) -----
# Personal access token + repo/workflow to dispatch a GitHub Actions build.
# GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GH_REPO=Suphanat10/IPO
# GH_WORKFLOW=build.yml
# Base URL used when constructing build callbacks.
# On Vercel, VERCEL_URL is provided automatically — set this only for self-host.
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# ----- Node runtime (OPTIONAL) -----
# Raise heap to avoid OOM while bundling the large ipo.json during dev/build.
# NODE_OPTIONS=--max-old-space-size=4096

# ----- Upcoming-IPO scraper (OPTIONAL — only the Python/scrape pipeline) -----
# SCRAPER_SEC_PAGE_MODE=missing          # missing | full
# SCRAPER_SEC_DOC_MODE=missing           # missing | full | skip
# SCRAPER_SEC_DOC_CACHE=1
# SCRAPER_SEC_DOC_CACHE_TTL_HOURS=168
# SCRAPER_SEC_PAGE_CACHE_TTL_MINUTES=30
# SCRAPER_SEC_FS_MAX_BYTES=5000000
# SCRAPER_SEC_WORKERS=3
# SCRAPER_SEC_DOC_WORKERS=3
# SCRAPER_RUN_TIMEOUT_MS=1800000
# SCRAPER_STALE_RUN_MS=2100000
